# Local development — copy to .env (never commit .env)
# Production checklist: see production.env.example and docs/PRODUCTION_ENV.md

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=3000
DB_PATH=./data/returnpal.db
FRONTEND_URL=http://localhost:3000

# Signup anti-spam
REGISTER_RATE_LIMIT_ENABLED=1
REGISTER_RATE_LIMIT_MAX=1
REGISTER_RATE_LIMIT_WINDOW_MS=86400000

# Local: 0 = instant approval. Production: set to 1 (see production.env.example)
SIGNUP_REQUIRE_ADMIN_APPROVAL=0

LOGIN_RATE_LIMIT_ENABLED=1
LOGIN_RATE_LIMIT_MAX=20
SIGNUP_MIN_FORM_SECONDS=3

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SIGNUP_TURNSTILE_REQUIRED=1
