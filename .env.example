# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Signup anti-spam (all optional except rate limits use defaults)
REGISTER_RATE_LIMIT_ENABLED=1
REGISTER_RATE_LIMIT_MAX=1
REGISTER_RATE_LIMIT_WINDOW_MS=86400000

# Require admin approval before new self-service signups can log in
SIGNUP_REQUIRE_ADMIN_APPROVAL=0
LOGIN_RATE_LIMIT_ENABLED=1
LOGIN_RATE_LIMIT_MAX=20
SIGNUP_MIN_FORM_SECONDS=3

# Cloudflare Turnstile (recommended for production) — https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Set to 0 to disable Turnstile even when keys are present (e.g. local dev)
SIGNUP_TURNSTILE_REQUIRED=1
