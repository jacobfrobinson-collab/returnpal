{
  "name": "returnpal-backend",
  "version": "1.0.0",
  "description": "ReturnPal - Amazon Returns Processing Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/seed.js",
    "create-admin": "node create-admin-user.js",
    "set-admin": "node set-admin.js",
    "test": "node test/api.test.js",
    "test:e2e": "node test/e2e/client-smoke.js",
    "test:e2e:admin": "node test/e2e/admin-bulk-import.js",
    "auction:valuate": "node scripts/auction-valuation/index.js",
    "john-pye:scan": "node scripts/john-pye-browse-lots.js",
    "john-pye:scan:one": "node scripts/john-pye-browse-lots.js --single-page",
    "john-pye:rank": "node scripts/john-pye-ranked-valuation.js",
    "john-pye:rank:one": "node scripts/john-pye-ranked-valuation.js --single-page",
    "john-pye:rank:first": "node scripts/john-pye-ranked-valuation.js --single-page --max-lots 1",
    "john-pye:rank:first:comps": "node scripts/john-pye-ranked-valuation.js --single-page --max-lots 1 --comp-pricing",
    "john-pye:rank:all": "node scripts/john-pye-ranked-valuation.js --all-browse-pages",
    "john-pye:rank:all:safe": "node scripts/john-pye-ranked-valuation.js --all-browse-pages --max-browse-pages 50",
    "john-pye:lot": "node scripts/john-pye-ranked-valuation.js"
  },
  "keywords": [
    "returnpal",
    "amazon",
    "returns",
    "liquidation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "sql.js": "^1.12.0",
    "validator": "^13.15.35",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
