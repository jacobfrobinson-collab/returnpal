EBAY_EMAIL=
EBAY_PASSWORD=
RM_EMAIL=
RM_PASSWORD=
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
# Default in repo: 2025 payout workbook (override if needed)
GOOGLE_SHEET_URL=

# ebay-reconcile-list-vs-main-sheet.js: compare Seller Hub list to this workbook (.xlsx/.xls/.csv) instead of Google Sheet API/download
# EBAY_RECONCILE_COMPARE_FILE=C:\Users\You\Downloads\EVERY EBAY ORDER SHEET 2025.xlsx
# EBAY_RECONCILE_SCAN_ALL_COLUMNS=1   Optional: search every cell per row (default: column B / --order-column only)
#
# 2026 reconcile preset (optional — or use npm run ebay:reconcile:postage-queue:2026 and edit paths in package.json)
# EBAY_RECONCILE_POSTAGE_QUEUE_URL=https://docs.google.com/spreadsheets/d/1pd9VJDM12pXUv2ubq6ckTuntojm4uqazmbB4HibeXGo/edit?gid=0#gid=0
# EBAY_RECONCILE_COMPARE_FILE=C:\Users\You\Downloads\EVERY EBAY ORDER SHEET 2026.xlsx
# EBAY_ORDERS_LIST_URL=https://www.ebay.co.uk/sh/ord/?filter=status%3APAID_SHIPPED%2Ctimerange%3ACURRENTYEAR

# Optional paths and tuning
RM_XLS_PATH=
# Orders with no Royal Mail postage match (API append; needs GOOGLE_SERVICE_ACCOUNT_JSON)
