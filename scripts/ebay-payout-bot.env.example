RM_POSTAGE_QUEUE_ORDER_NUMBERS_ONLY=1
PLAYWRIGHT_SLOW_MO_MS=50

# Chrome profile testing
CHROME_PROFILE_NAME=JR ebay
CHROME_USER_DATA_DIR=

# Failed page capture output folder
EBAY_PAYOUT_DEBUG_DIR=scripts/ebay-payout-debug
