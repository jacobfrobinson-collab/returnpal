# ReturnPal — production environment (copy into your host's env / secrets)
# Do NOT commit a real .env file with secrets. Use this as a checklist only.
#
# Hosting: paste each line into your host's Environment UI, then redeploy.
# Render: see docs/RENDER.md

NODE_ENV=production
PORT=3000

# Required — generate a long random string
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

DB_PATH=./data/returnpal.db
# Reimbursement / avatar uploads — on Render use the same persistent disk as the DB, e.g.:
# UPLOAD_DIR=/var/lib/returnpal/data/uploads
FRONTEND_URL=https://www.returnpal.co.uk
PUBLIC_APP_URL=https://www.returnpal.co.uk

# ─── Outbound email (SMTP) — see docs/EMAIL.md ───
# EMAIL_ENABLED=1
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=apikey
# SMTP_PASS=
# SMTP_FROM=noreply@returnpal.co.uk
# WEEKLY_DIGEST_EMAIL_ENABLED=1
# MONTHLY_INVOICE_EMAIL_ENABLED=1
# TRANSACTIONAL_EMAIL_ENABLED=1
# ADMIN_QUERY_NOTIFY_ENABLED=1
# ADMIN_QUERY_NOTIFY_EMAIL=contact@returnpal.co.uk
# Password reset links expire after this many hours (forgot-password / reset-password.html)
# PASSWORD_RESET_TTL_HOURS=24
# WEEKLY_DIGEST_CRON=0 18 * * 0
# MONTHLY_INVOICE_CRON=0 9 1 * *
# MONTHLY_TRUST_CRON=30 9 1 * *
# WEEKLY_ACTION_CRON=0 19 * * 0
# REIMBURSEMENT_REMINDER_CRON=0 10 * * *
# INACTIVITY_CRON=0 11 * * 1
# BENCHMARK_ROLLUP_CRON=0 3 2 * *
# WEEKLY_DIGEST_TZ=Europe/London
# HIGH_VALUE_ALERT_GBP=500
# STALE_PACKAGE_DAYS=14
# LOYALTY_SILVER_RECOVERED_GBP=5000
# LOYALTY_GOLD_RECOVERED_GBP=25000
# LOYALTY_SILVER_PACKAGES=20
# LOYALTY_GOLD_PACKAGES=80
# BENCHMARK_MIN_COHORT=5

# Secure Jotform for bank transfer details (no bank data stored on ReturnPal)
# PAYOUT_BANK_DETAILS_FORM_URL=https://form.jotform.com/YOUR_FORM_ID
# PAYOUT_JOTFORM_CODE_FIELD=payout_verification_code
# PAYOUT_JOTFORM_EMAIL_FIELD=email
# PAYOUT_JOTFORM_WEBHOOK_SECRET=long-random-string-for-jotform-webhook-url

# ─── Signup: rate limit + admin approval (recommended for production) ───
REGISTER_RATE_LIMIT_ENABLED=1
REGISTER_RATE_LIMIT_MAX=1
REGISTER_RATE_LIMIT_WINDOW_MS=86400000

# 1 = new public signups wait for admin approval before they can log in
SIGNUP_REQUIRE_ADMIN_APPROVAL=1

SIGNUP_MIN_FORM_SECONDS=3
LOGIN_RATE_LIMIT_ENABLED=1
LOGIN_RATE_LIMIT_MAX=20

# Cloudflare Turnstile (strongly recommended) — https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SIGNUP_TURNSTILE_REQUIRED=1

# Client reimbursement cockpit + /api/reimbursement/* (on by default; set 0 to disable)
# CLIENT_REIMBURSEMENT_ENABLED=0

# Optional: commit SHA shown on /api/health
# RETURNPAL_GIT_COMMIT=

# Production: omit RETURNPAL_SOLD_DATES_LEGACY (calendar YYYY-MM-DD is default).
# Setting RETURNPAL_SOLD_DATES_LEGACY=1 on Render breaks sold list vs invoice months — remove and redeploy.
# Only for an unmigrated local DB copy:
# RETURNPAL_SOLD_DATES_LEGACY=1
